generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ModuleCategory {
  CORE
  BEEKEEPING
  KNOWLEDGE
  DOCUMENTS
  CONNECTED
  AI
}

enum ModuleActivationStatus {
  ENABLED
  DISABLED
}

enum ApiaryStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum HiveStatus {
  ACTIVE
  STORED
  MAINTENANCE
  ARCHIVED
}

enum ColonyStatus {
  ACTIVE
  WEAK
  LOST
  ARCHIVED
}

enum EquipmentTrackingMode {
  QUANTITY
  INDIVIDUAL
  HYBRID
}

enum EquipmentTypeStatus {
  ACTIVE
  ARCHIVED
}

enum EquipmentItemStatus {
  AVAILABLE
  IN_USE
  TO_CLEAN
  MAINTENANCE
  RETIRED
  LOST
}

enum EquipmentEventType {
  QUANTITY_ADJUSTED
  ITEM_CREATED
  STATUS_CHANGED
  MOVED
  CLEANED
  MAINTENANCE
  RETIRED
  NOTE
}

enum HiveMovementStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum HiveMovementReason {
  HONEY_FLOW
  POLLINATION
  WINTERING
  EMERGENCY
  HEALTH
  GROUPING
  OTHER
}

model Organization {
  id         String             @id @default(cuid())
  name       String
  type       String?
  status     OrganizationStatus @default(ACTIVE)
  settings   Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  archivedAt DateTime?

  memberships         Membership[]
  roles               Role[]
  organizationModules OrganizationModule[]
  apiaries            Apiary[]
  hives               Hive[]
  colonies            Colony[]
  equipmentTypes      EquipmentType[]
  equipmentStocks     EquipmentStock[]
  equipmentItems      EquipmentItem[]
  equipmentEvents     EquipmentEvent[]
  hiveMovements       HiveMovement[]

  @@index([status])
}

model User {
  id          String     @id @default(cuid())
  name        String?
  email       String     @unique
  status      UserStatus @default(ACTIVE)
  preferences Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  archivedAt  DateTime?

  memberships           Membership[]
  userModulePreferences UserModulePreference[]

  @@index([status])
}

model Membership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  roleId         String?
  status         MembershipStatus @default(INVITED)
  invitedAt      DateTime?
  joinedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization      Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role              Role?                        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  modulePreferences MembershipModulePreference[]
  authoredHiveMovements HiveMovement[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([status])
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@unique([organizationId, code])
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model ModuleDefinition {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  category    ModuleCategory
  description String?
  isSystem    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organizationModules         OrganizationModule[]
  userModulePreferences       UserModulePreference[]
  membershipModulePreferences MembershipModulePreference[]

  @@index([category])
}

model OrganizationModule {
  id             String                 @id @default(cuid())
  organizationId String
  moduleId       String
  status         ModuleActivationStatus @default(DISABLED)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module       ModuleDefinition @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([organizationId, moduleId])
  @@index([moduleId])
  @@index([status])
}

model UserModulePreference {
  id        String                 @id @default(cuid())
  userId    String
  moduleId  String
  status    ModuleActivationStatus @default(DISABLED)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  module ModuleDefinition @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([moduleId])
  @@index([status])
}

model MembershipModulePreference {
  id           String                 @id @default(cuid())
  membershipId String
  moduleId     String
  status       ModuleActivationStatus @default(DISABLED)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  membership Membership       @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  module     ModuleDefinition @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, moduleId])
  @@index([moduleId])
  @@index([status])
}

model Apiary {
  id                  String       @id @default(cuid())
  organizationId      String
  name                String
  description         String?
  locationDescription String?
  latitude            Decimal?     @db.Decimal(9, 6)
  longitude           Decimal?     @db.Decimal(9, 6)
  accessNotes         String?
  status              ApiaryStatus @default(ACTIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  archivedAt          DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hives        Hive[]
  equipmentStocks EquipmentStock[]
  equipmentItems  EquipmentItem[]
  equipmentEvents EquipmentEvent[]
  sourceHiveMovements      HiveMovement[] @relation("HiveMovementSourceApiary")
  destinationHiveMovements HiveMovement[] @relation("HiveMovementDestinationApiary")

  @@index([organizationId])
  @@index([status])
}

model Hive {
  id                    String     @id @default(cuid())
  organizationId        String
  apiaryId              String?
  fieldIdentifier       String
  hiveType              String?
  lowPowerConfiguration Json?
  status                HiveStatus @default(ACTIVE)
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  archivedAt            DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiary       Apiary?      @relation(fields: [apiaryId], references: [id], onDelete: SetNull)
  colonies     Colony[]
  movementItems HiveMovementItem[]

  @@unique([organizationId, fieldIdentifier])
  @@index([apiaryId])
  @@index([status])
}

model Colony {
  id             String       @id @default(cuid())
  organizationId String
  hiveId         String?
  origin         String?
  queenKnown     Boolean      @default(false)
  queenYear      Int?
  status         ColonyStatus @default(ACTIVE)
  estimatedForce Int?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  archivedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hive         Hive?        @relation(fields: [hiveId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([hiveId])
  @@index([status])
}

model EquipmentType {
  id             String                @id @default(cuid())
  organizationId String?
  code           String?
  name           String
  category       String
  trackingMode   EquipmentTrackingMode @default(QUANTITY)
  defaultUnit    String?
  status         EquipmentTypeStatus   @default(ACTIVE)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  archivedAt     DateTime?

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  stocks       EquipmentStock[]
  items        EquipmentItem[]
  events       EquipmentEvent[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([category])
  @@index([status])
}

model EquipmentStock {
  id              String   @id @default(cuid())
  organizationId  String
  equipmentTypeId String
  apiaryId        String?
  quantity        Decimal  @db.Decimal(12, 3)
  unit            String
  locationLabel   String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id], onDelete: Restrict)
  apiary        Apiary?       @relation(fields: [apiaryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([equipmentTypeId])
  @@index([apiaryId])
}

model EquipmentItem {
  id              String              @id @default(cuid())
  organizationId  String
  equipmentTypeId String
  apiaryId        String?
  fieldIdentifier String
  status          EquipmentItemStatus @default(AVAILABLE)
  locationLabel   String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  archivedAt      DateTime?

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType    @relation(fields: [equipmentTypeId], references: [id], onDelete: Restrict)
  apiary        Apiary?          @relation(fields: [apiaryId], references: [id], onDelete: SetNull)
  events        EquipmentEvent[]

  @@unique([organizationId, fieldIdentifier])
  @@index([organizationId])
  @@index([equipmentTypeId])
  @@index([apiaryId])
  @@index([status])
}

model EquipmentEvent {
  id              String             @id @default(cuid())
  organizationId  String
  equipmentTypeId String?
  equipmentItemId String?
  apiaryId        String?
  eventType       EquipmentEventType
  quantity        Decimal?           @db.Decimal(12, 3)
  unit            String?
  sourceLocation  String?
  targetLocation  String?
  notes           String?
  occurredAt      DateTime           @default(now())
  createdAt       DateTime           @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType? @relation(fields: [equipmentTypeId], references: [id], onDelete: SetNull)
  equipmentItem EquipmentItem? @relation(fields: [equipmentItemId], references: [id], onDelete: SetNull)
  apiary        Apiary?        @relation(fields: [apiaryId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([equipmentTypeId])
  @@index([equipmentItemId])
  @@index([apiaryId])
  @@index([eventType])
  @@index([occurredAt])
}

model HiveMovement {
  id                  String             @id @default(cuid())
  organizationId      String
  sourceApiaryId      String?
  destinationApiaryId String
  authorMembershipId  String?
  departureDate       DateTime
  arrivalDate         DateTime?
  status              HiveMovementStatus @default(PLANNED)
  reason              HiveMovementReason @default(OTHER)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceApiary      Apiary?            @relation("HiveMovementSourceApiary", fields: [sourceApiaryId], references: [id], onDelete: SetNull)
  destinationApiary Apiary             @relation("HiveMovementDestinationApiary", fields: [destinationApiaryId], references: [id], onDelete: Restrict)
  authorMembership  Membership?        @relation(fields: [authorMembershipId], references: [id], onDelete: SetNull)
  items             HiveMovementItem[]

  @@index([organizationId])
  @@index([sourceApiaryId])
  @@index([destinationApiaryId])
  @@index([authorMembershipId])
  @@index([status])
  @@index([departureDate])
}

model HiveMovementItem {
  movementId String
  hiveId     String
  notes      String?
  createdAt  DateTime @default(now())

  movement HiveMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  hive     Hive         @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@id([movementId, hiveId])
  @@index([hiveId])
}
